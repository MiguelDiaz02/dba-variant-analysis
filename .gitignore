# =============================================================================
# .gitignore — DBA Variant Analysis Pipeline
# =============================================================================

# ── Privado / confidencial (NO subir a GitHub) ──────────────────────────────
DBA-context/
notebooks/
scripts/dba_analysis.py
scripts/generate_article_pdf.py
CLAUDE.md
.claude/

# ── Datos pesados / sensibles ───────────────────────────────────────────────
additional_files/
csv_files/
*.gz
*.csv

# ── Librería de terceros (no distribuir) ────────────────────────────────────
graph_background/

# ── Outputs generados (reproducibles desde el pipeline) ────────────────────
graphical_results/
graphical_results2/
reports/
imagenes/
pipeline.log
*.log

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Entornos virtuales ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDEs y editores ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Archivos temporales ─────────────────────────────────────────────────────
*.tmp
*.bak
~$*
